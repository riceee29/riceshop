'use client'
import { useEffect, useState } from 'react'
import { supabase } from '../lib/supabase'

export default function RiceShop() {
  const [user, setUser] = useState(null);
  const [profile, setProfile] = useState(null);
  const [assets, setAssets] = useState([]);
  const [email, setEmail] = useState('');
  const [password, setPassword] = useState('');

  useEffect(() => {
    fetchAssets();
    const { data: authListener } = supabase.auth.onAuthStateChange((event, session) => {
      setUser(session?.user ?? null);
      if (session?.user) fetchProfile(session.user.id);
    });
  }, []);

  async function fetchAssets() {
    const { data } = await supabase.from('assets').select('*');
    setAssets(data || []);
  }

  async function fetchProfile(userId) {
    const { data } = await supabase.from('profiles').select('*').eq('id', userId).single();
    setProfile(data);
  }

  async function handleLogin() {
    const { error } = await supabase.auth.signInWithPassword({ email, password });
    if (error) alert("로그인 실패: " + error.message);
  }

  async function handleSignUp() {
    const { error } = await supabase.auth.signUp({ email, password });
    if (error) alert("회원가입 실패: " + error.message);
    else alert("가입 확인 이메일을 확인해주세요!");
  }

  async function buyAsset(asset) {
    if (!user) return alert("로그인이 필요합니다.");
    if (!profile || profile.balance < asset.price) return alert("잔액이 부족합니다.");

    const { error } = await supabase.from('profiles')
      .update({ balance: profile.balance - asset.price })
      .eq('id', user.id);

    if (!error) {
      await supabase.from('purchases').insert({ user_id: user.id, asset_id: asset.id });
      alert(`${asset.title} 구매 완료!`);
      fetchProfile(user.id);
    }
  }

  return (
    <div style={{ maxWidth: '1000px', margin: '0 auto', padding: '20px', fontFamily: 'sans-serif' }}>
      <header style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', borderBottom: '2px solid #333', paddingBottom: '20px' }}>
        <h1 style={{ color: '#333' }}>🍚 라이스 에셋 스토어</h1>
        {user ? (
          <div style={{ textAlign: 'right' }}>
            <div style={{ fontWeight: 'bold' }}>{user.email}</div>
            <div style={{ color: '#007bff' }}>보유 잔액: 💰{profile?.balance || 0}원</div>
            <button onClick={() => supabase.auth.signOut()} style={{ marginTop: '5px', cursor: 'pointer' }}>로그아웃</button>
          </div>
        ) : (
          <div style={{ display: 'flex', gap: '10px' }}>
            <input type="email" placeholder="이메일" onChange={e => setEmail(e.target.value)} style={{ padding: '5px' }} />
            <input type="password" placeholder="비번" onChange={e => setPassword(e.target.value)} style={{ padding: '5px' }} />
            <button onClick={handleLogin} style={{ cursor: 'pointer' }}>로그인</button>
            <button onClick={handleSignUp} style={{ cursor: 'pointer' }}>회원가입</button>
          </div>
        )}
      </header>

      <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fill, minmax(250px, 1fr))', gap: '20px', marginTop: '30px' }}>
        {assets.length > 0 ? assets.map(asset => (
          <div key={asset.id} style={{ backgroundColor: '#fff', border: '1px solid #ddd', padding: '15px', borderRadius: '10px', boxShadow: '0 2px 5px rgba(0,0,0,0.1)' }}>
            <img src={asset.image_url || 'https://via.placeholder.com/250'} style={{ width: '100%', height: '150px', objectFit: 'cover', borderRadius: '5px' }} />
            <h2 style={{ fontSize: '1.2rem', margin: '10px 0' }}>{asset.title}</h2>
            <p style={{ color: '#666', fontSize: '0.9rem', height: '40px', overflow: 'hidden' }}>{asset.description}</p>
            <p style={{ fontWeight: 'bold', fontSize: '1.1rem', color: '#28a745' }}>{asset.price.toLocaleString()}원</p>
            <button 
              onClick={() => buyAsset(asset)}
              style={{ width: '100%', padding: '10px', backgroundColor: '#333', color: '#fff', border: 'none', borderRadius: '5px', cursor: 'pointer', fontWeight: 'bold' }}
            >
              구매하기
            </button>
          </div>
        )) : (
          <p style={{ textAlign: 'center', gridColumn: '1/-1', padding: '50px', color: '#999' }}>등록된 상품이 없습니다. Supabase에서 상품을 추가해주세요!</p>
        )}
      </div>
    </div>
  )
}
